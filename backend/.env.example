# ====== Infarm CS Backend — Konfigurasi ======
# Salin file ini menjadi ".env" lalu isi nilainya.

# API key Claude (Anthropic). Dapatkan di: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model Claude (default sesuai Tech Stack claude.md)
CLAUDE_MODEL=claude-sonnet-4-6

# Maksimum token balasan (jawaban CS singkat 2-5 kalimat → 600 cukup)
MAX_TOKENS=600

# Port server
PORT=3000
